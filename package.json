{
  "name": "hiring-automation",
  "version": "1.0.0",
  "description": "Automated hiring workflow",
  "main": "src/server.js",
  "scripts": {
    "test": "node --test --test-concurrency=1 tests/*.test.js",
    "start": "node src/server.js",
    "dev": "node --watch src/server.js",
    "db:migrate": "node src/db/migrate.js",
    "db:migrate:status": "node src/db/migrate.js --status",
    "db:seed": "node src/db/seed.js",
    "worker:gmail": "node src/workers/gmail-intake.js",
    "worker:gmail:watch": "node src/workers/gmail-intake.js --watch",
    "worker:parser": "node src/workers/doc-parser.js",
    "worker:parser:watch": "node src/workers/doc-parser.js --watch"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Chammy01/Hiring-Automation.git"
